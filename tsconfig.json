{
  "compilerOptions": {
    "baseUrl": ".",
    "lib": ["ESNext"],
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",

    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": false,
    "noEmit": true,
    "paths": {
      "#/*": ["./src/*"],
      "#app/*": ["./src/app/*"],
      "#auth/*": ["./src/auth/*"],
      "#scripts/*": ["./src/scripts/*"],
      "#test/*": ["./test/*"],

      "$/*": ["./src/common/*"],
      "$decorators/*": ["./src/common/decorators/*"],
      "$dto/*": ["./src/common/dto/*"],
      "$interceptors/*": ["./src/common/interceptors/*"],
      "$mapper/*": ["./src/common/mapper/*"],
      "$modules/*": ["./src/common/modules/*"],
      "$utils/*": ["./src/common/utils/*"],

      "~/*": ["./src/routes/*"],
      "~facility/*": ["./src/routes/facility/*"],
      "~frigo/*": ["./src/routes/frigo/*"],
      "~laundry/*": ["./src/routes/laundry/*"],
      "~push/*": ["./src/routes/push/*"],
      "~stay/*": ["./src/routes/stay/*"],
      "~user/*": ["./src/routes/user/*"],
      "~meal/*": ["./src/routes/meal/*"],
      "~wakeup/*": ["./src/routes/wakeup/*"],
      "*": ["./src/*"]
    },

    "strict": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  }
}
